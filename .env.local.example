# Notion
NOTION_TOKEN=secret_xxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Sign-In (OAuth 2.0 Web client ID from Google Cloud Console)
GOOGLE_CLIENT_ID=1234567890-abcdef.apps.googleusercontent.com

# Comma-separated allowlist — only these Google accounts can use the app
ALLOWED_GOOGLE_EMAILS=you@gmail.com

# Random long secret for signing session cookies (e.g. openssl rand -hex 32)
SESSION_SECRET=replace_with_a_long_random_string
